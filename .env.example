# 服务器配置
PORT=3000

# CLI 提供方：claude 或 codex
CLI_PROVIDER=claude

# Claude/Codex CLI 路径
CLAUDE_CLI_PATH=/root/.nvm/versions/node/v24.14.0/bin/claude
CODEX_CLI_PATH=/root/.nvm/versions/node/v24.14.0/bin/codex

# Codex 上下文自动归档阈值（0.9 表示 90%）
CODEX_CONTEXT_ARCHIVE_THRESHOLD=0.9

# Claude 上下文窗口大小（用于估算使用率，默认 200000）
# 实际优先使用 Claude CLI result 事件 modelUsage 里的真实 contextWindow
CLAUDE_CONTEXT_WINDOW=200000

# Claude 上下文自动归档阈值（默认关闭；设置为 0.9 表示 90% 后自动归档）
CLAUDE_CONTEXT_ARCHIVE_THRESHOLD=0

# 归档命令超时（毫秒）
ARCHIVE_COMMAND_TIMEOUT_MS=600000

# 兼容旧配置：未设置 CLAUDE_CLI_PATH 时会读取 CLI_PATH
# CLI_PATH=/root/.nvm/versions/node/v24.14.0/bin/claude

# 新建 Session 时前端可输入项目目录；默认值在页面中为 /root/remote_codex

# 管理员账户（首次启动时创建）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# JWT 密钥（请使用随机字符串）
JWT_SECRET=your_random_secret_key_here

# Token 有效期（可选，默认7天）
# JWT_EXPIRY=7d
